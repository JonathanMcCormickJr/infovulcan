{
  "Args": [],
  "Env": {
    "LISTEN_ADDR": "0.0.0.0:8084",
    "ADMIN_ADDR": "https://admin:8083",
    "CHAOS_AUTH_TOKEN": "REPLACE_WITH_CHAOS_TOKEN",
    "TLS_CA_CERT": "/etc/infovulcan/certs/ca.crt",
    "TLS_CERT": "/etc/infovulcan/certs/chaos.crt",
    "TLS_KEY": "/etc/infovulcan/certs/chaos.key",
    "TLS_DOMAIN": "chaos",
    "RUST_LOG": "info"
  },
  "MapDirs": {
    "./certs/chaos": "/etc/infovulcan/certs"
  },
  "RunConfig": {
    "Ports": ["8084"],
    "Memory": "256m"
  },
  "BaseVolumeSz": "512m"
}
