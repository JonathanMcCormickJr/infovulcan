{
  "Args": [],
  "Env": {
    "LISTEN_ADDR": "0.0.0.0:8085",
    "ADMIN_ADDR": "https://admin:8083",
    "TLS_CA_CERT": "/etc/infovulcan/certs/ca.crt",
    "TLS_CERT": "/etc/infovulcan/certs/honeypot.crt",
    "TLS_KEY": "/etc/infovulcan/certs/honeypot.key",
    "TLS_DOMAIN": "honeypot",
    "RUST_LOG": "info"
  },
  "MapDirs": {
    "./certs/honeypot": "/etc/infovulcan/certs"
  },
  "RunConfig": {
    "Ports": ["8085"],
    "Memory": "256m"
  },
  "BaseVolumeSz": "512m"
}
