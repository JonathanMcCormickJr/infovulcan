{
  "Args": [],
  "Env": {
    "LISTEN_ADDR": "0.0.0.0:8082",
    "DB_ADDR": "https://db-1:50051",
    "STORAGE_PATH": "/data/auth-keys",
    "JWT_SECRET": "REPLACE_WITH_SHARED_SECRET",
    "TLS_CA_CERT": "/etc/infovulcan/certs/ca.crt",
    "TLS_CERT": "/etc/infovulcan/certs/auth.crt",
    "TLS_KEY": "/etc/infovulcan/certs/auth.key",
    "TLS_DOMAIN": "auth",
    "RUST_LOG": "info"
  },
  "Dirs": ["data"],
  "MapDirs": {
    "./certs/auth": "/etc/infovulcan/certs"
  },
  "RunConfig": {
    "Ports": ["8082"],
    "Memory": "256m"
  },
  "BaseVolumeSz": "512m"
}
