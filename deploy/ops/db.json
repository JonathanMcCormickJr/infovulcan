{
  "Args": [],
  "Env": {
    "NODE_ID": "1",
    "LISTEN_ADDR": "0.0.0.0:50051",
    "RAFT_PEERS": "1:db-1:50051,2:db-2:50051,3:db-3:50051",
    "STORAGE_PATH": "/data/db",
    "TLS_CA_CERT": "/etc/infovulcan/certs/ca.crt",
    "TLS_CERT": "/etc/infovulcan/certs/db.crt",
    "TLS_KEY": "/etc/infovulcan/certs/db.key",
    "TLS_DOMAIN": "db",
    "RUST_LOG": "info"
  },
  "Dirs": ["data"],
  "MapDirs": {
    "./certs/db": "/etc/infovulcan/certs"
  },
  "RunConfig": {
    "Ports": ["50051"],
    "Memory": "512m"
  },
  "BaseVolumeSz": "1g"
}
