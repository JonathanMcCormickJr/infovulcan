{
  "Args": [],
  "Env": {
    "NODE_ID": "1",
    "LISTEN_ADDR": "0.0.0.0:8081",
    "RAFT_PEERS": "1:custodian-1:8081,2:custodian-2:8081,3:custodian-3:8081",
    "STORAGE_PATH": "/data/custodian",
    "DB_LEADER_ADDR": "https://db-1:50051",
    "LOCK_TTL_SECS": "900",
    "TLS_CA_CERT": "/etc/infovulcan/certs/ca.crt",
    "TLS_CERT": "/etc/infovulcan/certs/custodian.crt",
    "TLS_KEY": "/etc/infovulcan/certs/custodian.key",
    "TLS_DOMAIN": "custodian",
    "RUST_LOG": "info"
  },
  "Dirs": ["data"],
  "MapDirs": {
    "./certs/custodian": "/etc/infovulcan/certs"
  },
  "RunConfig": {
    "Ports": ["8081"],
    "Memory": "512m"
  },
  "BaseVolumeSz": "1g"
}
